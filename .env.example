# Copy to .env for local development. Never commit .env.

# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+asyncpg://jobsearch:jobsearch@localhost:5432/jobsearch
DATABASE_URL_SYNC=postgresql+psycopg://jobsearch:jobsearch@localhost:5432/jobsearch

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Ingestion
INGESTION_USER_AGENT=job-search-mvp/0.1 (contact: you@example.com)
INGESTION_REQUEST_TIMEOUT=20
INGESTION_CONCURRENCY=5
